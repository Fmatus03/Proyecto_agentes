APP_ENV=production
APP_PUBLIC_URL=https://brewmaster.example.com
API_BASE_URL=/api/v1

DB_HOST=db
DB_PORT=3306
DB_NAME=brewmaster
DB_USER=brewmaster
DB_PASSWORD=setme
DB_ROOT_PASSWORD=setme

JWT_SECRET_KEY=setme
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alerts@example.com
