  "validations": [
    {
      "id": "V001",
      "text": "`user_id` obligatorio en todas las operaciones manuales."
    },
    {
      "id": "V002",
      "text": "`created_at` obligatorio y con zona horaria del sistema."
    },
    {
      "id": "V003",
      "text": "`updated_at` obligatorio en entidades modificables."
    },
    {
      "id": "V004",
      "text": "`status` obligatorio en toda entidad con ciclo de vida."
    },
    {
      "id": "V005",
      "text": "IDs deben ser enteros positivos o UUID seg\u00fan entidad."
    },
    {
      "id": "V006",
      "text": "Fechas deben rechazar formatos inv\u00e1lidos."
    },
    {
      "id": "V007",
      "text": "No aceptar campos de texto con solo espacios en blanco."
    },
    {
      "id": "V008",
      "text": "Longitud m\u00e1xima de texto respetar l\u00edmites definidos por campo."
    },
    {
      "id": "V009",
      "text": "Correos deben tener formato v\u00e1lido RFC 5321."
    },
    {
      "id": "V010",
      "text": "Tel\u00e9fonos deben tener longitud m\u00ednima de 7 d\u00edgitos."
    },
    {
      "id": "V011",
      "text": "Campos monetarios deben tener exactamente dos decimales."
    },
    {
      "id": "V012",
      "text": "Montos no pueden ser NaN ni nulos si participan en totales."
    },
    {
      "id": "V013",
      "text": "Cantidades deben ser num\u00e9ricas y no NaN."
    },
    {
      "id": "V014",
      "text": "Cantidades deben tener m\u00e1ximo cuatro decimales."
    },
    {
      "id": "V015",
      "text": "Usuario autenticado obligatorio en toda llamada protegida."
    },
    {
      "id": "V016",
      "text": "Usuario inactivo debe recibir HTTP 401 al autenticar."
    },
    {
      "id": "V017",
      "text": "Contrase\u00f1a debe tener m\u00ednimo 8 caracteres."
    },
    {
      "id": "V018",
      "text": "Contrase\u00f1a nunca almacenable en texto plano."
    },
    {
      "id": "V019",
      "text": "Token JWT expirado debe rechazarse con HTTP 401."
    },
    {
      "id": "V020",
      "text": "Rol obligatorio para usuario activo."
    },
    {
      "id": "V021",
      "text": "Rol inactivo no puede asignarse a usuario."
    },
    {
      "id": "V022",
      "text": "Correo de usuario \u00fanico por empresa."
    },
    {
      "id": "V023",
      "text": "Intentos fallidos de login deben registrarse en auditor\u00eda."
    },
    {
      "id": "V024",
      "text": "Cambio de contrase\u00f1a exige contrase\u00f1a actual correcta."
    }
