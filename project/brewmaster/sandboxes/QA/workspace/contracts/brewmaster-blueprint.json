{
  "architecture_source": "fabricas_agentes_ia.md",
  "blueprint_id": "brewmaster.sdd.hito1.v1",
  "business_rules": [
    {
      "id": 1,
      "text": "Todo registro operativo debe pertenecer a una empresa."
    },
    {
      "id": 2,
      "text": "Todo usuario debe tener un rol asignado y activo."
    },
    {
      "id": 3,
      "text": "Todo cambio cr\u00edtico debe registrarse en auditor\u00eda con usuario, fecha, entidad, acci\u00f3n e IP."
    },
    {
      "id": 4,
      "text": "Los registros con historial operativo no se eliminan f\u00edsicamente."
    },
    {
      "id": 5,
      "text": "La eliminaci\u00f3n l\u00f3gica cambia estado a inactivo o cancelado."
    },
    {
      "id": 6,
      "text": "Las contrase\u00f1as deben almacenarse siempre encriptadas con bcrypt o equivalente."
    },
    {
      "id": 7,
      "text": "Un usuario inactivo no puede iniciar sesi\u00f3n."
    },
    {
      "id": 8,
      "text": "Solo el rol admin puede gestionar usuarios y roles."
    },
    {
      "id": 9,
      "text": "Los permisos se eval\u00faan por rol en cada operaci\u00f3n de API."
    },
    {
      "id": 10,
      "text": "Un usuario sin permiso recibe HTTP 403, nunca datos parciales."
    },
    {
      "id": 60,
      "text": "Solo admin y auditor pueden acceder al reporte de auditor\u00eda."
    }
  ],
